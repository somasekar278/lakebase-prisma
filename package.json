{
  "name": "prisma-multi-db-migrations-starter",
  "version": "1.0.0",
  "private": true,
  "description": "CI-driven Prisma migrations to a root Postgres and independent child Postgres endpoints",
  "scripts": {
    "db:generate": "node ./node_modules/prisma/build/index.js generate",
    "db:migrate:deploy": "node ./node_modules/prisma/build/index.js migrate deploy",
    "db:migrate:dev": "node ./node_modules/prisma/build/index.js migrate dev",
    "db:validate": "node ./node_modules/prisma/build/index.js validate",
    "db:format:check": "node ./node_modules/prisma/build/index.js format --check"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "~6.19.0",
    "prisma": "~6.19.0"
  }
}
