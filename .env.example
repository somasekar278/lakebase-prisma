# Local development — Prisma reads DATABASE_URL (and SHADOW_DATABASE_URL for `migrate dev`).

# Primary Lakebase branch (or any dev Postgres). Database name here matches the demo: migrations_demo.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/migrations_demo?schema=public&sslmode=require"

# Only for `prisma migrate dev`. Empty DB on the same branch; same role grants as migrations_demo.
# Ignored by `migrate deploy`.
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/migrations_demo_shadow?schema=public&sslmode=require"

# ---------------------------------------------------------------------------
# Apply the same migrations to root + 2 child branches at once:
#   ./scripts/migrate-all-local.sh
# Uncomment and set all three (same URL shape as DATABASE_URL; host differs per Lakebase branch).
# Prisma does not read these — only the script does (it runs migrate deploy once per URL).
# ---------------------------------------------------------------------------
# DATABASE_URL_ROOT="postgresql://USER:PASSWORD@ROOT-HOST:5432/migrations_demo?schema=public&sslmode=require"
# DATABASE_URL_CHILD_1="postgresql://USER:PASSWORD@CHILD1-HOST:5432/migrations_demo?schema=public&sslmode=require"
# DATABASE_URL_CHILD_2="postgresql://USER:PASSWORD@CHILD2-HOST:5432/migrations_demo?schema=public&sslmode=require"
#
# Do not commit real URLs or passwords to Git.
