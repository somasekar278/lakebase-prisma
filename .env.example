# Local development: point at one Postgres (e.g. Docker or cloud dev instance).
# Prisma reads DATABASE_URL from the environment for migrate, generate, and the client.

DATABASE_URL="postgresql://app:app@localhost:5432/migrations_demo_root?schema=public"

# Used only by `prisma migrate dev`. Create an empty DB (e.g. migrations_demo_shadow) and grant
# the same role access. Managed Postgres often blocks CREATE DATABASE — this avoids that.
# Ignored by `migrate deploy`. Same host/user/password as DATABASE_URL, different db name.
SHADOW_DATABASE_URL="postgresql://app:app@localhost:5432/migrations_demo_shadow?schema=public"

# ---------------------------------------------------------------------------
# GitHub Actions (repository secrets)
# ---------------------------------------------------------------------------
# The deploy workflow replays the same migration folder to three endpoints.
# Configure these as encrypted secrets; never commit real URLs or passwords.
#
#   DATABASE_URL_ROOT   — production or staging "root" catalog / primary DB
#   DATABASE_URL_CHILD_1 — first branch / tenant / region DB (same schema target)
#   DATABASE_URL_CHILD_2 — second branch DB
#
# Each URL is a standard Postgres connection string, for example:
#   postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require
#
# Child URLs are independent databases. This pattern applies DDL from Git; it does
# not copy row data between root and children.
