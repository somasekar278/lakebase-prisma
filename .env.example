# Local development — Prisma reads DATABASE_URL (and SHADOW_DATABASE_URL for `migrate dev`).

# Primary Lakebase branch (or any dev Postgres). Database name here matches the demo: migrations_demo.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/migrations_demo?schema=public&sslmode=require"

# Only for `prisma migrate dev`. Empty DB on the same branch; same role grants as migrations_demo.
# Ignored by `migrate deploy`.
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/migrations_demo_shadow?schema=public&sslmode=require"

# ---------------------------------------------------------------------------
# Multi-database migrate (scripts/migrate-all-local.sh) — optional; add if you replay to root + children.
# Same URL shape as DATABASE_URL; different host per Lakebase branch. Not read by Prisma directly.
# ---------------------------------------------------------------------------
# DATABASE_URL_ROOT="postgresql://..."
# DATABASE_URL_CHILD_1="postgresql://..."
# DATABASE_URL_CHILD_2="postgresql://..."
#
# Do not commit real URLs or passwords to Git.
